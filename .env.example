# ────────────────────────────────────────────────────────────────────
# gitsols-platform — environment variables
# Copy to `.env` (root, picked up by both apps in dev) or per-app `.env`.
# Validated at boot via:
#   - apps/api/src/config/env.schema.ts  (API)
#   - apps/web/src/env.ts                (web — added in Phase 1)
# ────────────────────────────────────────────────────────────────────

# ── Runtime ─────────────────────────────────────────────────────────
NODE_ENV=development

# ── API server ──────────────────────────────────────────────────────
PORT=4000
LOG_LEVEL=info
LOG_PRETTY=true
CORS_ORIGINS=http://localhost:3000

# Rate limiting (per IP, per window)
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# ── Database (Postgres + Drizzle) ───────────────────────────────────
# Local dev (docker run -p 5432:5432 postgres:16):
DATABASE_URL=postgres://gitsols:gitsols@localhost:5432/gitsols
# Production: use a managed Postgres (Neon, Render, RDS). Always require SSL:
#   DATABASE_URL=postgres://user:pass@host:5432/gitsols?sslmode=require

# Optional: max pool size for the API's pg client
DATABASE_POOL_MAX=10

# ── Auth ────────────────────────────────────────────────────────────
# Shared secret for signing Auth.js JWTs. Generate with:
#   openssl rand -base64 32
AUTH_SECRET=replace-me-with-openssl-rand-base64-32
AUTH_ISSUER=https://admin.gitsols.com

# Auth.js base URL — set per environment
AUTH_URL=http://localhost:3000

# Microsoft Entra (M365 SSO) — register an app at https://entra.microsoft.com
AUTH_MICROSOFT_ENTRA_ID=
AUTH_MICROSOFT_ENTRA_SECRET=
AUTH_MICROSOFT_ENTRA_TENANT_ID=common

# Google Workspace SSO — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── Email (Postmark) — used for magic-link auth + transactional ─────
POSTMARK_API_TOKEN=
POSTMARK_FROM_ADDRESS=no-reply@gitsols.com
# Inbox that receives new-lead notifications from the marketing site.
# Defaults to POSTMARK_FROM_ADDRESS if unset.
LEAD_NOTIFICATION_TO=info@gitsols.com

# ── Object storage (Cloudflare R2 — S3-compatible) ──────────────────
S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_DOCUMENTS=gitsols-documents

# ── Web (Next.js) — public env vars must be prefixed with NEXT_PUBLIC_ ──
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Observability ───────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Dev-mode admin bypass — true lets you reach /admin/* without signing in.
# NEVER set true in production (env.ts rejects it).
ADMIN_DEV_BYPASS=false
NEXT_PUBLIC_ADMIN_DEV_BYPASS=false
