{
  "name": "gitsols-platform",
  "version": "0.2.0",
  "private": true,
  "description": "GITSOLS platform — Turborepo (Next.js 16 + NestJS 11) powering the GITSOLS marketing site, admin/CRM, and client portal.",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "build:packages": "tsc -b packages/types packages/utils packages/constants",
    "clean:packages": "rm -rf packages/*/dist packages/*/tsconfig.tsbuildinfo",
    "lint": "turbo lint",
    "test": "turbo test",
    "type-check": "turbo type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "dev:web": "turbo dev --filter=@gitsols/web",
    "dev:api": "turbo dev --filter=@gitsols/api",
    "build:web": "turbo build --filter=@gitsols/web",
    "build:api": "turbo build --filter=@gitsols/api",
    "db:generate": "pnpm --filter @gitsols/api db:generate",
    "db:migrate": "pnpm --filter @gitsols/api db:migrate",
    "db:push": "pnpm --filter @gitsols/api db:push",
    "db:studio": "pnpm --filter @gitsols/api db:studio",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.1",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prettier": "^3.4.2",
    "turbo": "^2.9.10",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
