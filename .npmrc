# pnpm configuration for the gitsols-platform monorepo.
# These settings are deliberate — change with a PR note explaining why.

# Auto-install peer deps. Default in pnpm 8+, set explicitly so we don't
# regress if a future pnpm flips the default back.
auto-install-peers=true

# Don't fail the install on peer-dep mismatches. Next.js 16, NestJS 11, and
# the React 19.2 ecosystem still ship occasional drifted peers and we'd
# rather see the warning than block CI.
strict-peer-dependencies=false

# Default node_modules layout (isolated). Symlinked workspaces, .pnpm store,
# strict module resolution. If a transitive dep ever can't find its
# hoisted runtime (looking at you, drizzle-kit and some Next plugins),
# add it to `public-hoist-pattern[]` below — never flip to shamefully-hoist
# globally.

# Force a couple of widely-required peers to the top of node_modules so
# Next.js / Nest tooling can resolve them without surprises.
public-hoist-pattern[]="*eslint*"
public-hoist-pattern[]="*prettier*"
public-hoist-pattern[]="@types/*"

# Lockfile is the source of truth; never auto-write to a different format.
lockfile=true
inject-workspace-packages=true
